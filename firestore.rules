rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'gjyoshimanohar@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidPost(data) {
      return data.title is string &&
             data.slug is string &&
             data.content is string;
    }

    // Default deny global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if isAdmin() && isValidPost(request.resource.data);
      allow delete: if isAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
    
    // Admin list
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if true; 
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Todos collection
    match /todos/{todoId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
    }

    // Applications collection (Client Dashboard)
    match /applications/{applicationId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Documents collection (Client Dashboard)
    match /documents/{documentId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Compliance filings collection (Client Dashboard)
    match /compliance_filings/{filingId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Chats collection (Direct messaging between admin and clients)
    match /chats/{chatId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.clientScopeId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.clientScopeId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || request.resource.data.clientScopeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Client Requests collection
    match /client_requests/{requestId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if true;
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // Client Logins collection
    match /client_logins/{loginId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // Finances collection
    match /finances/{financeId} {
      allow read, write: if isAdmin();
    }

    // Payment Accounts collection
    match /payment_accounts/{accountId} {
      allow read, write: if isAdmin();
    }
  }
}
