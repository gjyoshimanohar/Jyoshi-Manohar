{
  "entities": {
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "readTime": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "content", "excerpt", "category", "date"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    },
    "Application": {
      "title": "Application",
      "description": "CA service application engagement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "currentStep": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "status", "createdAt"]
    },
    "ClientDocument": {
      "title": "Client Document",
      "description": "Metadata for client-facing generated documents and reports",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "fileType": { "type": "string" },
        "size": { "type": "string" },
        "uploadedAt": { "type": "number" }
      },
      "required": ["id", "userId", "name", "url", "uploadedAt"]
    },
    "ComplianceFiling": {
      "title": "Compliance Filing",
      "description": "Real-time compliance tracker status for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "serviceType": { "type": "string" },
        "dueDate": { "type": "number" },
        "status": { "type": "string" },
        "financialYear": { "type": "string" },
        "period": { "type": "string" },
        "arn": { "type": "string" }
      },
      "required": ["id", "userId", "title", "dueDate", "status"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Message exchanged between admin and client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientScopeId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderEmail": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "number" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "string" },
        "fileType": { "type": "string" }
      },
      "required": ["clientScopeId", "senderId", "senderEmail", "text", "timestamp"]
    },
    "ClientRequest": {
      "title": "Client Request",
      "description": "A customized proposal or compliance service request submitted by a client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "clientName": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["task", "document", "engagement"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "string" },
        "fileType": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] }
      },
      "required": ["userId", "clientName", "title", "type", "category", "createdAt", "status"]
    },
    "PortalNotification": {
      "title": "Portal Notification",
      "description": "Real-time communication and operational alerts triggered per client user account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "number" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["request", "document", "general", "chat"] }
      },
      "required": ["userId", "title", "message", "createdAt", "read", "type"]
    },
    "FinanceRecord": {
      "title": "Finance Record",
      "description": "An income or expense transaction log for CA admin financial management",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "createdAt": { "type": "number" },
        "clientName": { "type": "string" },
        "clientId": { "type": "string" },
        "paymentMode": { "type": "string" },
        "paymentAccountId": { "type": "string" }
      },
      "required": ["id", "type", "category", "amount", "date", "status", "createdAt"]
    },
    "PaymentAccount": {
      "title": "Payment Account",
      "description": "A payment account like a bank account or credit card for tracking funds and transactions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["bank_account", "credit_card"] },
        "openingBalance": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "type", "openingBalance", "createdAt"]
    }
  },
  "firestore": {
    "posts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "applications/{applicationId}": {
      "schema": "Application",
      "description": "Tax and corporate applications status"
    },
    "documents/{documentId}": {
      "schema": "ClientDocument",
      "description": "Client report files and certificates"
    },
    "compliance_filings/{filingId}": {
      "schema": "ComplianceFiling",
      "description": "Real-time compliance filing items"
    },
    "chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Exchanged message entries between consulting agents"
    },
    "client_requests/{requestId}": {
      "schema": "ClientRequest",
      "description": "Submissions or proposal inquiries from clients to be review by the administration"
    },
    "notifications/{notificationId}": {
      "schema": "PortalNotification",
      "description": "System operational context notifications displayed inside notifications bell UI"
    },
    "finances/{financeId}": {
      "schema": "FinanceRecord",
      "description": "Financial transaction logs for the CA administration"
    },
    "payment_accounts/{accountId}": {
      "schema": "PaymentAccount",
      "description": "Bank accounts and credit cards registered for payment sources"
    }
  }
}
